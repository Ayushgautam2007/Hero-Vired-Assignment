#!/bin/bash
set -euo pipefail

# Variables
DATE=$(date +"%F_%H-%M-%S")
BACKUP_DIR="/usr/local/Backup"
BACKUP_FILE="$BACKUP_DIR/nginx_backup_$DATE.tar.gz"
LOGFILE="$BACKUP_DIR/nginx_backup.log"
NGINX_SERVICE="nginx"

# Logging function
log() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') : $1" | tee -a "$LOGFILE"
}

log "========== Nginx Backup Script Started =========="

# Check if backup directory exists
if [ ! -d "$BACKUP_DIR" ]; then
    mkdir -p "$BACKUP_DIR"
    log "Backup directory created: $BACKUP_DIR"
fi

# Check if Nginx service is running
if systemctl is-active --quiet $NGINX_SERVICE; then
    log "Nginx service is running."
else
    log "WARNING: Nginx service is NOT running!"
fi

# Create backup
tar -czf "$BACKUP_FILE" /etc/nginx /usr/share/nginx/html 2>>"$LOGFILE"

# Check backup status
if [ $? -eq 0 ]; then
    log "Backup created successfully: $BACKUP_FILE"
else
    log "ERROR: Backup failed!"
    exit 1
fi

# Verify backup contents
log "Verifying backup contents..."
tar -tzf "$BACKUP_FILE" >>"$LOGFILE" 2>&1

log "Backup verification completed."

log "========== Nginx Backup Script Finished =========="
